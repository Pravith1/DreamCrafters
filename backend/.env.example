# PostgreSQL connection string
# Replace with your actual PostgreSQL credentials
DATABASE_URL="postgresql://username:password@localhost:5432/dreamcrafters?schema=public"
GROQ_API_KEY=your_groq_api_key_here
# Server port
PORT=5000

# JWT Secret and Expiry
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production
JWT_EXPIRES_IN=30d

# Email Configuration (for verification emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@dreamcrafters.com

# Frontend URL (for email verification links)
FRONTEND_URL=http://localhost:5173

# Embedding Provider for RAG (gemini or ollama)
EMBEDDING_PROVIDER=transformers
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama config (only if using ollama for embeddings)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text

# RAG config
# RAG_CHUNK_SIZE=500
# RAG_CHUNK_OVERLAP=50
# MAX_UPLOAD_SIZE_MB=10